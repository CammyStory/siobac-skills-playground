# Force LF line endings for all text files across all platforms, so the
# dist/ drift check in CI passes on Windows runners (whose Git defaults
# to core.autocrlf=true, which would otherwise convert LF → CRLF on
# checkout and trip the `git status --porcelain dist/` comparison).

* text=auto eol=lf

*.ts   text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.sh   text eol=lf
